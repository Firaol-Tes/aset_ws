<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="robotic_arm">

  <!--
    ╔═══════════════════════════════════════════════════════════════╗
    ║  SolidWorks-export normalization notes                        ║
    ╠═══════════════════════════════════════════════════════════════╣
    ║  The original SW URDF exporter placed the world origin far    ║
    ║  from the physical robot (SW assembly origin ≠ robot base).   ║
    ║                                                               ║
    ║  joint0 had xyz="0.70796 -1.3272 0.9075" — the SW world       ║
    ║  translation offset — and rpy="1.6757 0.094954 1.9904".       ║
    ║                                                               ║
    ║  CHANGES MADE:                                                ║
    ║  1. world_joint added (world → base_link, fixed):             ║
    ║     rpy=0.1294 -0.0573 -0.0037 — derived from PCA plane fit   ║
    ║     on bottom-face triangles (8.1° tilt in SW export).        ║
    ║     z=+0.029710 m lifts base plate bottom to world z=0.       ║
    ║  2. joint0 xyz zeroed → arm base sits at world origin.        ║
    ║  3. joint0 rpy kept unchanged: it encodes the actual physical ║
    ║     mounting orientation of lower_arm on the base plate.      ║
    ║  4. base_link visual/collision origin shifted by              ║
    ║     −(joint0_xyz) = (−0.70796, 1.3272, −0.9075) so the base  ║
    ║     plate mesh re-aligns with the arm at world origin.        ║
    ║     (base_link.STL vertices are in SW world coordinates.)     ║
    ║  5. base_link inertial COM is still in SW world coords —      ║
    ║     correct it before enabling simulation/dynamics.           ║
    ║  6. joint6 limits corrected: −1.57..0 (finger closes pos→0). ║
    ║  7. joint7 limits corrected: −1.57..0, mimic joint6 ×(+1).  ║
    ║     Multiplier is +1 because joint6/joint7 frames are rotated ║
    ║     180° in yaw, making their local Z axes antiparallel in    ║
    ║     the parent frame. Equal joint values → opposite world     ║
    ║     rotations → symmetric pinch. multiplier=−1 (wrong) caused ║
    ║     both fingers to rotate in the same world direction.       ║
    ║  8. All mesh URIs updated: Robotic_Arm → robotic_arm_description║
    ║  9. joint1–7 origins: UNTOUCHED (relative transforms exact). ║
    ╚═══════════════════════════════════════════════════════════════╝
  -->

  <!-- ═══════ world ══════════════════════════════════════════════ -->
  <!-- Massless anchor so RViz/Nav2 have a stable "world" fixed frame. -->
  <link name="world"/>

  <!--
    world_joint — world → base_link  (fixed)
    Values derived by fitting a plane to the 17 bottom-face triangles of
    base_link.STL and computing the rotation that maps the plane normal
    onto world Z.

    Bottom-face plane normal in base_link = [0.0573, 0.1288, 0.9900]
      → 8.1° off vertical in base_link coords (plate is genuinely tilted
        in the SW export, not just a translation issue).

    rpy = "0.129355 -0.057284 -0.003711"  (roll 7.4°, pitch −3.3°, yaw −0.2°)
      Rotates base_link so the bottom face is horizontal in world frame.

    xyz z = 0.029710 m
      After applying the rpy, the lowest mesh vertex sits at world Z =
      −0.029710 m; lifting by that amount places the bottom at z = 0.
  -->
  <joint name="world_joint" type="fixed">
    <origin xyz="0 0 0.029710" rpy="0.129355 -0.057284 -0.003711"/>
    <parent link="world"/>
    <child  link="base_link"/>
  </joint>

  <!-- ═══════ base_link ═══════════════════════════════════════════ -->
  <link name="base_link">
    <inertial>
      <!-- COM is in SW world coordinates — subtract (0.70796, −1.3272, 0.9075)
           before using this link in a dynamics simulation. -->
      <origin xyz="0.70723 0.89479 1.3289" rpy="0 0 0"/>
      <mass value="0.19084"/>
      <inertia ixx="0.00014713" ixy="6.8937E-06"  ixz="-8.9675E-07"
               iyy="0.00026594" iyz="-1.5506E-05" izz="0.00014875"/>
    </inertial>
    <!-- Visual/collision shifted by −(old joint0 xyz) so the base plate mesh
         renders adjacent to the arm, which now lives at world origin. -->
    <visual>
      <origin xyz="-0.70796 1.3272 -0.9075" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/base_link.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="-0.70796 1.3272 -0.9075" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- ═══════ lower_arm ══════════════════════════════════════════ -->
  <link name="lower_arm">
    <inertial>
      <origin xyz="-0.034789 0.052024 4.4209E-05" rpy="0 0 0"/>
      <mass value="0.19613"/>
      <inertia ixx="0.00038821" ixy="0.00032912"  ixz="5.654E-07"
               iyy="0.00038835" iyz="-6.0057E-07" izz="0.00072024"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/lower_arm.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/lower_arm.STL"/>
      </geometry>
    </collision>
  </link>

  <!--
    joint0 — base_link → lower_arm  (shoulder pan / first revolute)
    CHANGED xyz: "0.70796 -1.3272 0.9075" → "0 0 0"
      Reason: the XYZ was the SW world-origin offset, not a physical
      transform. Zeroing places the arm at world origin.
    KEPT rpy: "1.6757 0.094954 1.9904"
      Reason: encodes the physical mounting angle of lower_arm on the
      base plate as measured in the SW assembly. Zeroing it would
      misalign every downstream mesh.
  -->
  <joint name="joint0" type="revolute">
    <origin xyz="0 0 0" rpy="1.6757 0.094954 1.9904"/>
    <parent link="base_link"/>
    <child  link="lower_arm"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ═══════ upper_arm ══════════════════════════════════════════ -->
  <link name="upper_arm">
    <inertial>
      <origin xyz="0.030278 0.032273 -0.019925" rpy="0 0 0"/>
      <mass value="0.081835"/>
      <inertia ixx="9.6287E-05"  ixy="-7.8192E-05" ixz="-1.6357E-06"
               iyy="7.9895E-05"  iyz="-1.7788E-06"  izz="0.00017026"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/upper_arm.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/upper_arm.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- joint1 — lower_arm → upper_arm  UNCHANGED -->
  <joint name="joint1" type="revolute">
    <origin xyz="-0.1 0.12129 0" rpy="0 0 -0.97771"/>
    <parent link="lower_arm"/>
    <child  link="upper_arm"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ═══════ shoulder_drive ══════════════════════════════════════ -->
  <link name="shoulder_drive">
    <inertial>
      <origin xyz="0.0053519 -4.4717E-05 0.010345" rpy="0 0 0"/>
      <mass value="0.036284"/>
      <inertia ixx="1.6274E-05"  ixy="-5.7101E-10" ixz="2.109E-07"
               iyy="1.6305E-05"  iyz="-1.2692E-08"  izz="4.537E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/shoulder_drive.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/shoulder_drive.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- joint2 — upper_arm → shoulder_drive  UNCHANGED -->
  <joint name="joint2" type="revolute">
    <origin xyz="0.08 0.09 0" rpy="1.9556 -1.5708 0"/>
    <parent link="upper_arm"/>
    <child  link="shoulder_drive"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ═══════ rotary_yoke ══════════════════════════════════════════ -->
  <link name="rotary_yoke">
    <inertial>
      <origin xyz="0.0034544 -8.8589E-10 -1.5216E-10" rpy="0 0 0"/>
      <mass value="0.015723"/>
      <inertia ixx="4.9761E-06"  ixy="2.7011E-13"  ixz="1.3689E-13"
               iyy="8.6886E-06"  iyz="1.0867E-12"   izz="6.6823E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/rotary_yoke.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/rotary_yoke.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- joint3 — shoulder_drive → rotary_yoke  UNCHANGED -->
  <joint name="joint3" type="revolute">
    <origin xyz="0.005 0 0.077514" rpy="1.1002 1.5708 0"/>
    <parent link="shoulder_drive"/>
    <child  link="rotary_yoke"/>
    <axis xyz="1 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ═══════ wrist_module ══════════════════════════════════════════ -->
  <link name="wrist_module">
    <inertial>
      <origin xyz="0.0052933 6.3561E-10 3.6458E-10" rpy="0 0 0"/>
      <mass value="0.034187"/>
      <inertia ixx="3.7152E-06"  ixy="4.4265E-13"   ixz="1.2545E-13"
               iyy="8.9897E-06"  iyz="-9.6955E-13"  izz="9.0316E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/wrist_module.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/wrist_module.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- joint4 — rotary_yoke → wrist_module  UNCHANGED -->
  <joint name="joint4" type="revolute">
    <origin xyz="-0.025486 0 0" rpy="0 0 1.8687"/>
    <parent link="rotary_yoke"/>
    <child  link="wrist_module"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="8" velocity="1"/>
  </joint>

  <!-- ═══════ gripper_actuator ══════════════════════════════════════ -->
  <link name="gripper_actuator">
    <inertial>
      <origin xyz="-3.7917E-09 -9.0172E-09 0.0059505" rpy="0 0 0"/>
      <mass value="0.015789"/>
      <inertia ixx="1.6581E-06" ixy="4.1866E-12"  ixz="5.5925E-13"
               iyy="1.6959E-06" iyz="8.6177E-13"   izz="1.8592E-06"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_actuator.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_actuator.STL"/>
      </geometry>
    </collision>
  </link>

  <!-- joint5 — wrist_module → gripper_actuator  UNCHANGED -->
  <joint name="joint5" type="revolute">
    <origin xyz="0.03356 0 0" rpy="-1.5708 0.5658 -1.5708"/>
    <parent link="wrist_module"/>
    <child  link="gripper_actuator"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
  </joint>

  <!-- ═══════ gripper_1 (left finger) ══════════════════════════════ -->
  <link name="gripper_1">
    <inertial>
      <origin xyz="0.018895 0.0012108 5.4008E-08" rpy="0 0 0"/>
      <mass value="0.0029088"/>
      <inertia ixx="5.5054E-08"  ixy="-3.6466E-08" ixz="-5.9482E-12"
               iyy="5.6195E-07"  iyz="6.3354E-14"   izz="5.2896E-07"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_1.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_1.STL"/>
      </geometry>
    </collision>
  </link>

  <!--
    joint6 — gripper_actuator → gripper_1  (left finger)
    Positive rotation = finger opens outward.
    lower="-0.093": almost-closed resting position (slight pre-contact).
    upper="1.57":   fully open (~90°).
    Origin UNCHANGED.
  -->
  <joint name="joint6" type="revolute">
    <origin xyz="-0.011 0 0.02344" rpy="1.5708 -1.5034 0"/>
    <parent link="gripper_actuator"/>
    <child  link="gripper_1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.093" upper="1.57" effort="2" velocity="1"/>
  </joint>

  <!-- ═══════ gripper_2 (right finger) ══════════════════════════════ -->
  <link name="gripper_2">
    <inertial>
      <origin xyz="0.018895 0.0012108 5.2626E-08" rpy="0 0 0"/>
      <mass value="0.0029088"/>
      <inertia ixx="5.5055E-08"  ixy="-3.6466E-08" ixz="-5.9756E-12"
               iyy="5.6195E-07"  iyz="3.1914E-14"   izz="5.2896E-07"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_2.STL"/>
      </geometry>
      <material name="arm_color">
        <color rgba="0.79216 0.81961 0.93333 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robotic_arm_description/meshes/gripper_2.STL"/>
      </geometry>
    </collision>
  </link>

  <!--
    joint7 — gripper_actuator → gripper_2  (right finger)
    Mirrors joint6 via mimic multiplier=+1.
    Limits match joint6 exactly: lower="-0.093" upper="1.57".
    Because joint7's frame is rotated 180° in yaw relative to joint6,
    equal joint values produce opposite physical rotations → symmetric
    pinch.  joint6=1.57 AND joint7=1.57 → both fingers open outward.
    Origin UNCHANGED.
  -->
  <joint name="joint7" type="revolute">
    <origin xyz="0.011 0 0.02344" rpy="1.5708 -1.5034 3.1416"/>
    <parent link="gripper_actuator"/>
    <child  link="gripper_2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.093" upper="1.57" effort="2" velocity="1"/>
    <mimic joint="joint6" multiplier="1" offset="0"/>
  </joint>

  <!-- ═══════ ros2_control hardware interface ══════════════════════
       mock_components/GenericSystem simulates hardware for the demo.
       Swap the plugin for a real driver (e.g. serial, EtherCAT) in
       production.  joint7 is declared as a mimic so controller_manager
       keeps its state in sync with joint6 automatically.
  ══════════════════════════════════════════════════════════════════ -->
  <ros2_control name="robotic_arm_system" type="system">
    <hardware>
      <plugin>mock_components/GenericSystem</plugin>
    </hardware>

    <joint name="joint0">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint1">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint2">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint5">
      <command_interface name="position">
        <param name="min">-3.14</param><param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <joint name="joint6">
      <command_interface name="position">
        <param name="min">-0.093</param><param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
    <!-- joint7 is a URDF mimic joint: ros2_control 4.x forbids command interfaces on mimic joints. -->
    <joint name="joint7">
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"><param name="initial_value">0.0</param></state_interface>
    </joint>
  </ros2_control>

</robot>
